# Server environment example
PORT=5000
NODE_ENV=production
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/powerpulsepro?retryWrites=true&w=majority
JWT_SECRET=your_secure_jwt_secret_here
CLIENT_URL=https://your-frontend.onrender.com

# Development-only defaults (do not use in production)
DEFAULT_ADMIN_EMAIL=admin@powerpulsepro.local
DEFAULT_ADMIN_PASSWORD=Admin@12345
SEED_EVENTS=true
# Environment Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/powerpulsepro

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_here_change_in_production
JWT_EXPIRES_IN=7d

# Client Configuration
CLIENT_URL=https://powerpulseproo-1.onrender.com
CLIENT_URLS=https://powerpulseproo-1.onrender.com

# Email Configuration (for notifications)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Admin Configuration
ADMIN_EMAIL=powerpulsepro.smartmetering@gmail.com
ADMIN_PASSWORD=admin123

# Security
BCRYPT_SALT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100